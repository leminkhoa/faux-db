{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kuriboh.example/schema/v1/schema-file.schema.json",
  "title": "Kuriboh schema file (v1)",
  "type": "object",
  "minProperties": 1,
  "maxProperties": 1,
  "additionalProperties": {
    "$ref": "#/$defs/TableSchema"
  },
  "$defs": {
    "TableSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows", "columns", "output"],
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 1
        },
        "columns": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/ColumnConfig"
          }
        },
        "output": {
          "$ref": "#/$defs/OutputConfig"
        }
      }
    },
    "OutputConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "filepath"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["csv", "json"],
          "default": "csv"
        },
        "filepath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "RelStrategy": {
      "type": "string",
      "enum": ["random", "sequential"],
      "default": "random"
    },
    "ColumnConfig": {
      "oneOf": [
        { "$ref": "#/$defs/FakerColumn" },
        { "$ref": "#/$defs/FuncColumn" },
        { "$ref": "#/$defs/RelColumn" },
        { "$ref": "#/$defs/ProviderColumn" }
      ]
    },
    "CommonColumnFields": {
      "type": "object",
      "properties": {
        "bind_to": { "type": "string" },
        "unique": { "type": "boolean", "default": false }
      }
    },
    "FakerColumn": {
      "allOf": [
        { "$ref": "#/$defs/CommonColumnFields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "method"],
          "properties": {
            "type": { "const": "faker" },
            "method": { "type": "string", "minLength": 1 },
            "params": { "type": "object", "additionalProperties": true }
          }
        }
      ]
    },
    "FuncColumn": {
      "allOf": [
        { "$ref": "#/$defs/CommonColumnFields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "func"],
          "properties": {
            "type": { "const": "func" },
            "func": {
              "type": "string",
              "minLength": 3,
              "pattern": "^[^\\s]+\\.[^\\s]+$",
              "description": "Python callable path '<module>.<callable>'"
            },
            "params": { "type": "object", "additionalProperties": true }
          }
        }
      ]
    },
    "RelColumn": {
      "allOf": [
        { "$ref": "#/$defs/CommonColumnFields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "target"],
          "properties": {
            "type": { "const": "rel" },
            "target": {
              "type": "string",
              "minLength": 3,
              "pattern": "^[^\\s]+\\.[^\\s]+$",
              "description": "Foreign key target '<table>.<column>'"
            },
            "strategy": { "$ref": "#/$defs/RelStrategy" }
          }
        }
      ]
    },
    "ProviderColumn": {
      "allOf": [
        { "$ref": "#/$defs/CommonColumnFields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "target"],
          "properties": {
            "type": { "const": "provider" },
            "target": { "type": "string", "minLength": 1 },
            "mode": {
              "type": "string",
              "enum": ["sample", "lookup"],
              "default": "sample"
            },
            "column": { "type": ["string", "null"] },
            "sample": { "$ref": "#/$defs/SampleConfig" },
            "lookup": { "$ref": "#/$defs/LookupConfig" }
          },
          "allOf": [
            {
              "if": { "properties": { "mode": { "const": "lookup" } }, "required": ["mode"] },
              "then": { "required": ["lookup"] }
            },
            {
              "if": { "properties": { "mode": { "const": "sample" } }, "required": ["mode"] },
              "then": {
                "not": { "required": ["lookup"] }
              }
            }
          ]
        }
      ]
    },
    "SampleConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["sequential", "random", "shuffle"],
          "default": "sequential"
        },
        "seed": { "type": ["integer", "null"] }
      }
    },
    "LookupConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_columns", "key_from", "value_column"],
      "properties": {
        "key_columns": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "key_from": {
          "description": "Bare schema column name(s) used to build the lookup key (string or list of strings).",
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          ]
        },
        "value_column": { "type": "string", "minLength": 1 },
        "on_missing": {
          "type": "string",
          "enum": ["null", "error", "default"],
          "default": "null"
        },
        "default_value": { "type": ["string", "number", "boolean", "object", "array", "null"] }
      }
    }
  }
}

